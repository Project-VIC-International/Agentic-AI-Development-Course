{
  "@context": {
    "case-investigation": "https://ontology.caseontology.org/case/investigation/",
    "kb": "http://example.org/kb/",
    "uco-action": "https://ontology.unifiedcyberontology.org/uco/action/",
    "uco-core": "https://ontology.unifiedcyberontology.org/uco/core/",
    "uco-identity": "https://ontology.unifiedcyberontology.org/uco/identity/",
    "uco-observable": "https://ontology.unifiedcyberontology.org/uco/observable/",
    "uco-types": "https://ontology.unifiedcyberontology.org/uco/types/",
    "xsd": "http://www.w3.org/2001/XMLSchema#"
  },
  "@graph": [
    {
      "@id": "kb:investigation-bad",
      "@type": "case-investigation:Investigation",
      "uco-core:description": "This investigation is missing a required name field."
    },
    {
      "@id": "kb:device-bad",
      "@type": "uco-observable:Device",
      "uco-core:name": "Suspect Laptop"
    },
    {
      "@id": "kb:file-bad",
      "@type": "uco-observable:File"
    },
    {
      "@id": "kb:action-bad",
      "@type": "case-investigation:InvestigativeAction",
      "uco-core:name": "Extraction without examiner recorded",
      "uco-action:object": { "@id": "kb:device-bad" }
    },
    {
      "@id": "kb:identity-bad",
      "@type": "uco-identity:Identity",
      "uco-core:hasFacet": [
        {
          "@type": "uco-identity:SimpleNameFacet",
          "uco-identity:givenName": "Missing",
          "uco-identity:familyName": "Name"
        }
      ]
    }
  ]
}
